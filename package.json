{
  "name": "spindata",
  "version": "0.1.0",
  "description": "live game data relay service for SpinShare tournaments",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env index.js",
    "dev": "node --watch --env-file=.env index.js",
    "test": "node tests/test-match-registry.js && node tests/test-store.js && node tests/test-relay-judgments.js",
    "relay": "node --env-file=relay/.env relay/index.js",
    "build": "node scripts/build-relay.js"
  },
  "dependencies": {
    "ioredis": "^5.3.2",
    "ws": "^8.19.0"
  },
  "license": "ISC",
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.27.4"
  }
}
